{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TABI Article",
  "type": "object",
  "required": ["id", "title", "summary", "category", "tags", "publishedAt", "readingTime", "image", "imageAlt", "sections", "sourcePolicy", "verificationLevel", "lastChecked", "sourceNote"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "category": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "publishedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "readingTime": { "type": "number", "minimum": 1 },
    "image": { "type": "string" },
    "imageAlt": { "type": "string" },
    "sections": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["heading", "body"],
        "properties": {
          "heading": { "type": "string" },
          "body": { "type": "string" }
        }
      }
    },
    "sourcePolicy": { "type": "string" },
    "verificationLevel": { "type": "string" },
    "lastChecked": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "sourceNote": { "type": "string" }
  }
}

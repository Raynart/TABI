{
  "name": "tabi-static-site",
  "version": "0.1.0",
  "private": true,
  "description": "Local static site tooling for TABI.",
  "type": "module",
  "scripts": {
    "generate": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/generate-site.ps1",
    "validate": "node ./scripts/validate-site.mjs",
    "validate:data": "node ./scripts/validate-data.mjs",
    "validate:assets": "node ./scripts/validate-assets.mjs",
    "health": "node ./scripts/site-health.mjs",
    "audit:ops": "node ./scripts/audit-ops.mjs",
    "report": "node ./scripts/health-report.mjs",
    "dashboard": "node ./scripts/editorial-dashboard.mjs",
    "split:content": "node ./scripts/split-content.mjs",
    "new:article": "node ./scripts/new-article.mjs",
    "audit:content": "node ./scripts/site-health.mjs",
    "audit:i18n": "node ./scripts/validate-data.mjs",
    "check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-site.ps1",
    "visual": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/visual-check.ps1",
    "serve": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Start-LocalServer.ps1"
  },
  "engines": {
    "node": ">=18"
  }
}
